  "routing_policy": {
    "description": "Priority-based routing with automatic fallback. Lower priority number = preferred.",
    "rules": [
      "1. Try highest-priority provider with available capacity",
      "2. If rate limit hit, mark provider as exhausted and try next",
      "3. If all cloud providers exhausted, switch to local LLM",
      "4. Notify user on every provider switch",
      "5. Reset rate limit counters at midnight UTC for daily limits",
      "6. Reset rate limit counters after 1 minute for per-minute limits",
      "7. For OpenRouter with multiple keys, rotate keys before switching provider"
    ],
    "notification_events": [
      "provider_exhausted",
      "provider_switched",
      "key_rotated",
      "local_fallback_activated",
      "local_fallback_deactivated",
      "rate_limit_warning_80pct",
      "daily_limit_warning_80pct"
    ]
  }
